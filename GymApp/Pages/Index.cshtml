@page
@model GymApp.Pages.IndexModel

<div class="container mt-4">
    <h2 class="mb-4">📊 Dashboard</h2>

    @* Κάρτες στατιστικών *@
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h6 class="card-title">Σύνολο Μελών</h6>
                    <h2 class="card-text">@Model.TotalMembers</h2>
                    <small>Ενεργά: @Model.ActiveMembers</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h6 class="card-title">Ενεργές Συνδρομές</h6>
                    <h2 class="card-text">@Model.ActiveSubscriptions</h2>
                    <small>Ληγμένες: @Model.ExpiredSubscriptions</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h6 class="card-title">Προγράμματα</h6>
                    <h2 class="card-text">@Model.TotalPrograms</h2>
                    <small>Ενεργά προγράμματα</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h6 class="card-title">Έσοδα Μήνα</h6>
                    <h2 class="card-text">@Model.MonthlyRevenue.ToString("C", new System.Globalization.CultureInfo("el-GR"))</h2>
                    <small>Τρέχων μήνας</small>
                </div>
            </div>
        </div>
    </div>

    @* Top προγράμματα *@
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    🏆 Δημοφιλέστερα Προγράμματα
                </div>
                <div class="card-body">
                    @if (!Model.TopPrograms.Any())
                    {
                        <p class="text-muted">Δεν υπάρχουν δεδομένα.</p>
                    }
                    @foreach (var program in Model.TopPrograms)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>@program.ProgramName</span>
                            <span class="badge bg-primary">@program.Count ενεργές</span>
                        </div>
                        <div class="progress mb-3" style="height: 8px;">
                            <div class="progress-bar" style="width: @(program.Count * 100 / (Model.ActiveSubscriptions == 0 ? 1 : Model.ActiveSubscriptions))%"></div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Γρήγορες ενέργειες *@
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    ⚡ Γρήγορες Ενέργειες
                </div>
                <div class="card-body d-grid gap-2">
                    <a asp-page="/Members/Create" class="btn btn-outline-primary">+ Νέο Μέλος</a>
                    <a asp-page="/GymPrograms/Index" class="btn btn-outline-info">Διαχείριση Προγραμμάτων</a>
                    <a asp-page="/Trainers/Index" class="btn btn-outline-secondary">Διαχείριση Εκπαιδευτών</a>
                    <a asp-page="/Members/Index" class="btn btn-outline-success">Λίστα Μελών</a>
                </div>
            </div>
        </div>
       
    </div>
    @if (Model.ExpiringSubscriptions > 0)
    {
        <div class="alert alert-warning mt-4">
            <h5>⚠️ Ληγούσες Συνδρομές (επόμενες 7 μέρες)</h5>
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Μέλος</th>
                        <th>Πρόγραμμα</th>
                        <th>Λήξη</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sub in Model.ExpiringSoonList)
                    {
                        <tr>
                            <td>@sub.Member.Lastname @sub.Member.Firstname</td>
                            <td>@sub.SubscriptionPlan.GymProgram.Name</td>
                            <td>
                                @if (sub.EndDate == DateTime.Today)
                                {
                                    <span class="badge bg-danger">Σήμερα!</span>
                                }
                                else
                                {
                                    @sub.EndDate.ToShortDateString()
                                }
                            </td>
                            <td>
                                <a asp-page="/Subscriptions/Renew" asp-route-id="@sub.Id"
                                   class="btn btn-sm btn-success">Ανανέωση</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>