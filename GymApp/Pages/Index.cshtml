@page
@model GymApp.Pages.IndexModel

<div class="container mt-4">
    <h2 class="mb-4">📊 Dashboard</h2>

    @* Κάρτες στατιστικών *@
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card" style="border-top: 3px solid var(--accent) !important;">
                <div class="card-body">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
                        <span style="font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Σύνολο Μελών</span>
                        <i class="ti ti-users" style="color:var(--accent);font-size:1.1rem"></i>
                    </div>
                    <div style="font-family:var(--font-display);font-size:2.2rem;letter-spacing:2px;color:var(--text-1)">@Model.TotalMembers</div>
                    <div style="font-size:.7rem;color:var(--text-3);margin-top:4px">Ενεργά: @Model.ActiveMembers</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card" style="border-top: 3px solid var(--olive) !important;">
                <div class="card-body">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
                        <span style="font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Ενεργές Συνδρομές</span>
                        <i class="ti ti-id-badge" style="color:var(--olive);font-size:1.1rem"></i>
                    </div>
                    <div style="font-family:var(--font-display);font-size:2.2rem;letter-spacing:2px;color:var(--text-1)">@Model.ActiveSubscriptions</div>
                    <div style="font-size:.7rem;color:var(--text-3);margin-top:4px">Ληγμένες: @Model.ExpiredSubscriptions</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card" style="border-top: 3px solid var(--brown-mid) !important;">
                <div class="card-body">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
                        <span style="font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Προγράμματα</span>
                        <i class="ti ti-activity" style="color:var(--brown-mid);font-size:1.1rem"></i>
                    </div>
                    <div style="font-family:var(--font-display);font-size:2.2rem;letter-spacing:2px;color:var(--text-1)">@Model.TotalPrograms</div>
                    <div style="font-size:.7rem;color:var(--text-3);margin-top:4px">Ενεργά προγράμματα</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card" style="border-top: 3px solid var(--warm) !important;">
                <div class="card-body">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
                        <span style="font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Έσοδα Μήνα</span>
                        <i class="ti ti-cash" style="color:var(--warm);font-size:1.1rem"></i>
                    </div>
                    <div style="font-family:var(--font-display);font-size:2.2rem;letter-spacing:2px;color:var(--text-1)">@Model.MonthlyRevenue.ToString("C", new System.Globalization.CultureInfo("el-GR"))</div>
                    <div style="font-size:.7rem;color:var(--text-3);margin-top:4px">Τρέχων μήνας</div>
                </div>
            </div>
        </div>
    </div>

    @* Πίνακας διαθεσιμότητας Pilates Reformer *@
    <div class="card mb-4">
        <div class="card-header">
            🏋️ Διαθεσιμότητα Pilates Reformer
        </div>
        <div class="card-body">
            <table class="table table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Τμήμα</th>
                        <th>Συνολικές Θέσεις</th>
                        <th>Δεσμευμένες</th>
                        <th>Διαθέσιμες</th>
                        <th>Συνδρομές x4</th>
                        <th>Συνδρομές x8</th>
                        <th>Συνδρομές x12</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>🌅 Πρωί</strong></td>
                        <td>@Model.MorningCapacity.TotalSlots</td>
                        <td>@Model.MorningCapacity.OccupiedSlots</td>
                        <td>
                            <span class="badge @(Model.MorningCapacity.AvailableSlots > 10 ? "bg-success" : Model.MorningCapacity.AvailableSlots > 0 ? "bg-warning" : "bg-danger")">
                                @Model.MorningCapacity.AvailableSlots
                            </span>
                        </td>
                        <td>@Model.MorningCapacity.AvailableFor4</td>
                        <td>@Model.MorningCapacity.AvailableFor8</td>
                        <td>@Model.MorningCapacity.AvailableFor12</td>
                    </tr>
                    <tr>
                        <td><strong>🌆 Απόγευμα</strong></td>
                        <td>@Model.AfternoonCapacity.TotalSlots</td>
                        <td>@Model.AfternoonCapacity.OccupiedSlots</td>
                        <td>
                            <span class="badge @(Model.AfternoonCapacity.AvailableSlots > 10 ? "bg-success" : Model.AfternoonCapacity.AvailableSlots > 0 ? "bg-warning" : "bg-danger")">
                                @Model.AfternoonCapacity.AvailableSlots
                            </span>
                        </td>
                        <td>@Model.AfternoonCapacity.AvailableFor4</td>
                        <td>@Model.AfternoonCapacity.AvailableFor8</td>
                        <td>@Model.AfternoonCapacity.AvailableFor12</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    @* Top προγράμματα *@
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    🏆 Δημοφιλέστερα Προγράμματα
                </div>
                <div class="card-body">
                    @if (!Model.TopPrograms.Any())
                    {
                        <p class="text-muted">Δεν υπάρχουν δεδομένα.</p>
                    }
                    @foreach (var program in Model.TopPrograms)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>@program.ProgramName</span>
                            <span class="badge bg-primary">@program.Count ενεργές</span>
                        </div>
                        <div class="progress mb-3" style="height: 8px;">
                            <div class="progress-bar" style="width: @(program.Count * 100 / (Model.ActiveSubscriptions == 0 ? 1 : Model.ActiveSubscriptions))%"></div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Γρήγορες ενέργειες *@
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    ⚡ Γρήγορες Ενέργειες
                </div>
                <div class="card-body d-grid gap-2">
                    <a asp-page="/Members/Create" class="btn btn-outline-primary">+ Νέο Μέλος</a>
                    <a asp-page="/GymPrograms/Index" class="btn btn-outline-info">Διαχείριση Προγραμμάτων</a>
                    <a asp-page="/Trainers/Index" class="btn btn-outline-secondary">Διαχείριση Εκπαιδευτών</a>
                    <a asp-page="/Members/Index" class="btn btn-outline-success">Λίστα Μελών</a>
                </div>
            </div>
        </div>
       
    </div>
    @if (Model.ExpiringSubscriptions > 0)
    {
        <div class="alert alert-warning mt-4">
            <h5>⚠️ <a asp-page="/Reports/ExpiringSubscriptions" class="text-dark">Ληγούσες Συνδρομές (επόμενες 7 μέρες)</a></h5>
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Μέλος</th>
                        <th>Πρόγραμμα</th>
                        <th>Λήξη</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sub in Model.ExpiringSoonList)
                    {
                        <tr>
                            <td>@sub.Member.Lastname @sub.Member.Firstname</td>
                            <td>@sub.SubscriptionPlan.GymProgram.Name</td>
                            <td>
                                @if (sub.EndDate == DateTime.Today)
                                {
                                    <span class="badge bg-danger">Σήμερα!</span>
                                }
                                else
                                {
                                    @sub.EndDate.ToShortDateString()
                                }
                            </td>
                            <td>
                                <a asp-page="/Subscriptions/Renew" asp-route-id="@sub.Id"
                                   class="btn btn-sm btn-success">Ανανέωση</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>