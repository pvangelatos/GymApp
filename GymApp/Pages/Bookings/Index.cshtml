@page "{subscriptionId:int}"
@model GymApp.Pages.Bookings.IndexModel

<div class="d-flex justify-content-between align-items-end mb-4 pb-3" style="border-bottom: 1px solid var(--border)">
    <div>
        <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:2px;color:var(--text-3);margin-bottom:4px">
            <i class="ti ti-arrow-left"></i>
            <a asp-page="/Subscriptions/Index" asp-route-memberId="@Model.Subscription.MemberId" style="color:var(--text-3);text-decoration:none">Συνδρομές</a>
        </div>
        <h1 style="font-family:var(--font-display);font-size:2.5rem;letter-spacing:4px;color:var(--accent);line-height:1">ΚΡΑΤΗΣΕΙΣ</h1>
        <div style="font-size:.75rem;color:var(--text-3);margin-top:6px">
            <i class="ti ti-user" style="color:var(--accent)"></i>
            <strong style="color:var(--text-2)">@Model.Subscription.Member.Lastname @Model.Subscription.Member.Firstname</strong>
            &nbsp;·&nbsp;
            <span>@Model.Subscription.SubscriptionPlan.GymProgram.Name</span>
            &nbsp;·&nbsp;
            @if (Model.Subscription.SessionType == GymApp.Models.SessionType.Morning)
            {
                <span><i class="ti ti-sun" style="color:var(--warm)"></i> Πρωί</span>
            }
            else
            {
                <span><i class="ti ti-moon" style="color:var(--accent)"></i> Απόγευμα</span>
            }
        </div>
    </div>
    @if (Model.RemainingSessions > 0 && Model.Subscription.IsActive)
    {
        <a asp-page="Create" asp-route-subscriptionId="@Model.Subscription.Id" class="btn btn-primary"
               style="font-family:var(--font-display);letter-spacing:2px;font-size:.95rem;padding:10px 20px">
            <i class="ti ti-plus"></i> ΝΕΑ ΚΡΑΤΗΣΗ
        </a>
    }
</div>

@* Κάρτες στατιστικών *@
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card" style="border-top:3px solid var(--olive) !important">
            <div class="card-body">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                    <span style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Παρουσίες</span>
                    <i class="ti ti-check" style="color:var(--olive);font-size:1rem"></i>
                </div>
                <div style="font-family:var(--font-display);font-size:2rem;letter-spacing:2px;color:var(--text-1)">@Model.Bookings.Count(b => b.Status == GymApp.Models.BookingStatus.Attended)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card" style="border-top:3px solid var(--accent) !important">
            <div class="card-body">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                    <span style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Κρατήσεις</span>
                    <i class="ti ti-calendar" style="color:var(--accent);font-size:1rem"></i>
                </div>
                <div style="font-family:var(--font-display);font-size:2rem;letter-spacing:2px;color:var(--text-1)">@Model.Bookings.Count(b => b.Status == GymApp.Models.BookingStatus.Booked)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card" style="border-top:3px solid var(--warm) !important">
            <div class="card-body">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                    <span style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Εναπομείνασες</span>
                    <i class="ti ti-hourglass" style="color:var(--warm);font-size:1rem"></i>
                </div>
                <div style="font-family:var(--font-display);font-size:2rem;letter-spacing:2px;color:var(--text-1)">@Model.RemainingSessions</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card" style="border-top:3px solid var(--red) !important">
            <div class="card-body">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                    <span style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">No Show</span>
                    <i class="ti ti-user-x" style="color:var(--red);font-size:1rem"></i>
                </div>
                <div style="font-family:var(--font-display);font-size:2rem;letter-spacing:2px;color:var(--text-1)">@Model.Bookings.Count(b => b.Status == GymApp.Models.BookingStatus.NoShow)</div>
            </div>
        </div>
    </div>
</div>

@if (Model.RemainingSessions == 0)
{
    <div class="alert alert-warning mb-3">
        <i class="ti ti-alert-triangle"></i> Έχουν χρησιμοποιηθεί όλες οι συνεδρίες.
    </div>
}

<div class="card">
    <table class="table mb-0">
        <thead>
            <tr>
                <th>Ημερομηνία</th>
                <th>Ώρα</th>
                <th>Κατάσταση</th>
                <th>Ενέργειες</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Bookings.Any())
            {
                <tr>
                    <td colspan="4" class="text-center py-4" style="color:var(--text-3)">
                        <i class="ti ti-calendar-off" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                        Δεν υπάρχουν κρατήσεις.
                    </td>
                </tr>
            }
            @foreach (var booking in Model.Bookings)
            {
                <tr>
                    <td style="font-size:.82rem;font-family:var(--font-mono);white-space:nowrap">
                        @booking.BookingDate.ToShortDateString()
                    </td>
                    <td style="font-size:.82rem;font-family:var(--font-mono)">
                        @booking.TimeSlot.StartTime.ToString("HH:mm")
                    </td>
                    <td>
                        @switch (booking.Status)
                        {
                            case GymApp.Models.BookingStatus.Booked:
                                <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--accent-lt);color:var(--accent);font-weight:600">
                                    <i class="ti ti-clock"></i> Κράτηση
                                </span>
                                break;
                            case GymApp.Models.BookingStatus.Attended:
                                <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--olive-lt);color:var(--olive);font-weight:600">
                                    <i class="ti ti-check"></i> Παρουσία
                                </span>
                                break;
                            case GymApp.Models.BookingStatus.Cancelled:
                                <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--bg-4);color:var(--text-3);font-weight:600">
                                    <i class="ti ti-ban"></i> Ακυρώθηκε
                                </span>
                                break;
                            case GymApp.Models.BookingStatus.NoShow:
                                <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--red-lt);color:var(--red);font-weight:600">
                                    <i class="ti ti-user-x"></i> No Show
                                </span>
                                break;
                        }
                    </td>
                    <td>
                        @if (booking.Status == GymApp.Models.BookingStatus.Booked)
                        {
                            <div class="d-flex gap-2">
                                <form method="post" asp-page="UpdateStatus" asp-route-id="@booking.Id" asp-route-status="Attended">
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="ti ti-check"></i> Παρουσία
                                    </button>
                                </form>
                                <form method="post" asp-page="Cancel" asp-route-id="@booking.Id">
                                    <button type="submit" class="btn btn-sm btn-secondary">
                                        <i class="ti ti-ban"></i> Ακύρωση
                                    </button>
                                </form>
                                <form method="post" asp-page="UpdateStatus" asp-route-id="@booking.Id" asp-route-status="NoShow">
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="ti ti-user-x"></i> No Show
                                    </button>
                                </form>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>