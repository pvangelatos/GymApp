@page "{subscriptionId:int}"
@model GymApp.Pages.Bookings.CreateModel

<div class="mb-4 pb-3" style="border-bottom: 1px solid var(--border)">
    <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:2px;color:var(--text-3);margin-bottom:4px">
        <i class="ti ti-arrow-left"></i>
        <a asp-page="Index" asp-route-subscriptionId="@Model.Booking.SubscriptionId" style="color:var(--text-3);text-decoration:none">Κρατήσεις</a>
    </div>
    <h1 style="font-family:var(--font-display);font-size:3rem;letter-spacing:4px;color:var(--accent);line-height:1">ΝΕΑ ΚΡΑΤΗΣΗ</h1>
    <div style="font-size:.75rem;color:var(--text-3);margin-top:6px">
        <i class="ti ti-user" style="color:var(--accent)"></i>
        <strong style="color:var(--text-2)">@Model.Subscription.Member.Lastname @Model.Subscription.Member.Firstname</strong>
        &nbsp;·&nbsp;
        <span>@Model.Subscription.SubscriptionPlan.GymProgram.Name</span>
        &nbsp;·&nbsp;
        @if (Model.Subscription.SessionType == GymApp.Models.SessionType.Morning)
        {
            <span><i class="ti ti-sun" style="color:var(--warm)"></i> Πρωί</span>
        }
        else
        {
            <span><i class="ti ti-moon" style="color:var(--accent)"></i> Απόγευμα</span>
        }
    </div>
</div>

<div class="row">
    <div class="col-md-5">
        @if (!ModelState.IsValid)
        {
            <div class="alert alert-danger mb-3">
                @foreach (var error in ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p class="mb-0"><i class="ti ti-alert-circle"></i> @error.ErrorMessage</p>
                }
            </div>
        }

        @* Βήμα 1 *@
        <div class="card mb-3">
            <div class="card-header">
                <i class="ti ti-calendar" style="color:var(--accent)"></i> ΒΗΜΑ 1 — ΕΠΙΛΟΓΗ ΗΜΕΡΟΜΗΝΙΑΣ
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="SelectDate">
                    <input type="hidden" asp-for="Booking.SubscriptionId" />
                    <div class="input-group">
                        <input asp-for="SelectedDate" type="date" class="form-control"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-arrow-right"></i> Επιλογή
                        </button>
                    </div>
                </form>
            </div>
        </div>

        @* Βήμα 2 *@
        @if (Model.DateSelected && Model.TimeSlotList != null && Model.TimeSlotList.Any())
        {
            <div class="card">
                <div class="card-header">
                    <i class="ti ti-clock" style="color:var(--accent)"></i> ΒΗΜΑ 2 — ΕΠΙΛΟΓΗ ΩΡΑΣ
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="Save">
                        <input type="hidden" asp-for="Booking.SubscriptionId" />
                        <input type="hidden" asp-for="SelectedDate" />

                        <div class="mb-3">
                            <label asp-for="Booking.TimeSlotId" class="form-label">Διαθέσιμες Ώρες</label>
                            <select asp-for="Booking.TimeSlotId" asp-items="Model.TimeSlotList" class="form-select">
                                <option value="">-- Επιλέξτε Ώρα --</option>
                            </select>
                            <span asp-validation-for="Booking.TimeSlotId" class="text-danger" style="font-size:.75rem"></span>
                        </div>

                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="ti ti-device-floppy"></i> Αποθήκευση
                            </button>
                            <a asp-page="Index" asp-route-subscriptionId="@Model.Booking.SubscriptionId" class="btn btn-secondary">
                                <i class="ti ti-x"></i> Ακύρωση
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        }
        else if (Model.DateSelected)
        {
            <div class="alert alert-warning">
                <i class="ti ti-calendar-off"></i> Δεν υπάρχουν διαθέσιμες ώρες για αυτή την ημερομηνία.
            </div>
            <a asp-page="Index" asp-route-subscriptionId="@Model.Booking.SubscriptionId" class="btn btn-secondary">
                <i class="ti ti-arrow-left"></i> Επιστροφή
            </a>
        }
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}