@page "{id:int}"
@model GymApp.Pages.GymPrograms.DeleteModel

<div class="mb-4 pb-3" style="border-bottom: 1px solid var(--border)">
    <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:2px;color:var(--text-3);margin-bottom:4px">
        <i class="ti ti-arrow-left"></i>
        <a asp-page="Index" style="color:var(--text-3);text-decoration:none">Προγράμματα</a>
    </div>
    <h1 style="font-family:var(--font-display);font-size:3rem;letter-spacing:4px;color:var(--red);line-height:1">ΔΙΑΓΡΑΦΗ ΠΡΟΓΡΑΜΜΑΤΟΣ</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="alert alert-danger">
            <i class="ti ti-alert-triangle"></i> Είστε σίγουροι ότι θέλετε να διαγράψετε αυτό το πρόγραμμα;
        </div>
        <div class="card">
            <div class="card-body">
                <dl style="display:grid;grid-template-columns:1fr 2fr;gap:10px 16px">
                    <dt style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Όνομα</dt>
                    <dd style="font-size:.85rem;color:var(--text-1);margin:0">@Model.GymProgram.Name</dd>
                    <dt style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Περιγραφή</dt>
                    <dd style="font-size:.85rem;color:var(--text-1);margin:0">@Model.GymProgram.Description</dd>
                    <dt style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Εκπαιδευτής</dt>
                    <dd style="font-size:.85rem;color:var(--text-1);margin:0">@Model.GymProgram.Trainer.Firstname @Model.GymProgram.Trainer.Lastname</dd>
                </dl>
                <form method="post" class="mt-4">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="ti ti-trash"></i> Διαγραφή
                        </button>
                        <a asp-page="Index" class="btn btn-secondary">
                            <i class="ti ti-x"></i> Ακύρωση
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>