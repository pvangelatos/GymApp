@page "{id:int}"
@model GymApp.Pages.GymPrograms.EditModel

<div class="mb-4 pb-3" style="border-bottom: 1px solid var(--border)">
    <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:2px;color:var(--text-3);margin-bottom:4px">
        <i class="ti ti-arrow-left"></i>
        <a asp-page="Index" style="color:var(--text-3);text-decoration:none">Προγράμματα</a>
    </div>
    <h1 style="font-family:var(--font-display);font-size:3rem;letter-spacing:4px;color:var(--accent);line-height:1">ΕΠΕΞΕΡΓΑΣΙΑ ΠΡΟΓΡΑΜΜΑΤΟΣ</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="GymProgram.Id" />
                    <div class="mb-3">
                        <label asp-for="GymProgram.Name" class="form-label">Όνομα</label>
                        <input asp-for="GymProgram.Name" class="form-control" />
                        <span asp-validation-for="GymProgram.Name" class="text-danger" style="font-size:.75rem"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="GymProgram.Description" class="form-label">Περιγραφή</label>
                        <textarea asp-for="GymProgram.Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="GymProgram.Schedule" class="form-label">Πρόγραμμα</label>
                        <input asp-for="GymProgram.Schedule" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="GymProgram.TrainerId" class="form-label">Εκπαιδευτής</label>
                        <select asp-for="GymProgram.TrainerId" asp-items="Model.TrainerList" class="form-select">
                            <option value="">-- Επιλέξτε Εκπαιδευτή --</option>
                        </select>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-device-floppy"></i> Αποθήκευση
                        </button>
                        <a asp-page="Index" class="btn btn-secondary">
                            <i class="ti ti-x"></i> Ακύρωση
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}