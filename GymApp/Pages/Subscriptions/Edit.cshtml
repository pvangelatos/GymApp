@page "{id:int}"
@model GymApp.Pages.Subscriptions.EditModel

<div class="mb-4 pb-3" style="border-bottom: 1px solid var(--border)">
    <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:2px;color:var(--text-3);margin-bottom:4px">
        <i class="ti ti-arrow-left"></i>
        <a asp-page="Index" asp-route-memberId="@Model.Subscription.MemberId" style="color:var(--text-3);text-decoration:none">Συνδρομές</a>
    </div>
    <h1 style="font-family:var(--font-display);font-size:3rem;letter-spacing:4px;color:var(--accent);line-height:1">ΕΠΕΞΕΡΓΑΣΙΑ ΣΥΝΔΡΟΜΗΣ</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="Subscription.Id" />
                    <input type="hidden" asp-for="Subscription.MemberId" />
                    <input type="hidden" asp-for="Subscription.SubscriptionPlanId" />
                    <input type="hidden" asp-for="Subscription.AmountPaid" />

                    <div class="mb-3">
                        <label asp-for="Subscription.SubscriptionPlanId" class="form-label">Πακέτο</label>
                        <select asp-for="Subscription.SubscriptionPlanId" asp-items="Model.PlanList" class="form-select"></select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Subscription.SessionType" class="form-label">Τμήμα</label>
                        <select asp-for="Subscription.SessionType" asp-items="Model.SessionTypeList" class="form-select"></select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Subscription.StartDate" class="form-label">Ημερομηνία Έναρξης</label>
                        <input asp-for="Subscription.StartDate" type="date" class="form-control"
                               value="@Model.Subscription.StartDate.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Subscription.EndDate" class="form-label">Ημερομηνία Λήξης</label>
                        <input asp-for="Subscription.EndDate" type="date" class="form-control"
                               value="@Model.Subscription.EndDate.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="Subscription.IsActive" class="form-check-input" />
                            <label asp-for="Subscription.IsActive" class="form-check-label">Ενεργή</label>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-device-floppy"></i> Αποθήκευση
                        </button>
                        <a asp-page="Index" asp-route-memberId="@Model.Subscription.MemberId" class="btn btn-secondary">
                            <i class="ti ti-x"></i> Ακύρωση
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>