@page "{id:int}"
@model GymApp.Pages.Subscriptions.AttendanceCardModel

<div class="container mt-4" id="printArea">
    <div class="card border-2">
        <div class="card-header bg-dark text-white">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0">🏋️ GymApp — Κάρτα Παρουσιών</h4>
                <span class="badge bg-light text-dark fs-6">
                    @(Model.Subscription.IsActive ? "Ενεργή" : "Ληγμένη")
                </span>
            </div>
        </div>
        <div class="card-body">
            @* Στοιχεία μέλους *@
            <div class="row mb-4">
                <div class="col-md-6">
                    <table class="table table-sm table-borderless">
                        <tr>
                            <td class="fw-bold">Μέλος:</td>
                            <td>@Model.Subscription.Member.Lastname @Model.Subscription.Member.Firstname</td>
                        </tr>
                        <tr>
                            <td class="fw-bold">Πρόγραμμα:</td>
                            <td>@Model.Subscription.SubscriptionPlan.GymProgram.Name</td>
                        </tr>
                        <tr>
                            <td class="fw-bold">Τμήμα:</td>
                            <td>@(Model.Subscription.SessionType == GymApp.Models.SessionType.Morning ? "Πρωί" : "Απόγευμα")</td>
                        </tr>
                    </table>
                </div>
                <div class="col-md-6">
                    <table class="table table-sm table-borderless">
                        <tr>
                            <td class="fw-bold">Πακέτο:</td>
                            <td>@Model.Subscription.SubscriptionPlan.SessionsPerMonth συνεδρίες</td>
                        </tr>
                        <tr>
                            <td class="fw-bold">Έναρξη:</td>
                            <td>@Model.Subscription.StartDate.ToShortDateString()</td>
                        </tr>
                        <tr>
                            <td class="fw-bold">Λήξη:</td>
                            <td>@Model.Subscription.EndDate.ToShortDateString()</td>
                        </tr>
                    </table>
                </div>
            </div>

            @* Κουτάκια συνεδριών *@
            <h5 class="mb-3">Συνεδρίες</h5>
            <div class="row g-3">
                @foreach (var box in Model.SessionBoxes)
                {
                    <div class="col-6 col-md-3">
                        <div class="card text-center h-100 @(!box.IsEmpty ? (box.Booking!.Status == GymApp.Models.BookingStatus.Attended ? "bg-success text-white" : box.Booking.Status == GymApp.Models.BookingStatus.NoShow ? "bg-danger text-white" : "bg-warning") : "bg-light")">
                            <div class="card-body p-2">
                                <div class="fw-bold fs-5">#@box.Number</div>
                                @if (box.IsEmpty)
                                {
                                    <div class="text-muted small">—</div>
                                }
                                else
                                {
                                    <div class="small">@box.Booking!.BookingDate.ToShortDateString()</div>
                                    <div class="small">@box.Booking.TimeSlot.StartTime.ToString("HH:mm")</div>
                                    <div class="mt-1">
                                        @switch (box.Booking.Status)
                                        {
                                            case GymApp.Models.BookingStatus.Attended:
                                                <span>✓ Παρουσία</span>
                                                break;
                                            case GymApp.Models.BookingStatus.NoShow:
                                                <span>✗ No Show</span>
                                                break;
                                            case GymApp.Models.BookingStatus.Booked:
                                                <span>● Κράτηση</span>
                                                break;
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* Σύνοψη *@
            <div class="row mt-4">
                <div class="col">
                    <div class="d-flex gap-3">
                        <span><span class="badge bg-success">✓</span> Παρουσίες: @Model.SessionBoxes.Count(b => b.Booking?.Status == GymApp.Models.BookingStatus.Attended)</span>
                        <span><span class="badge bg-danger">✗</span> No Show: @Model.SessionBoxes.Count(b => b.Booking?.Status == GymApp.Models.BookingStatus.NoShow)</span>
                        <span><span class="badge bg-warning text-dark">●</span> Κρατήσεις: @Model.SessionBoxes.Count(b => b.Booking?.Status == GymApp.Models.BookingStatus.Booked)</span>
                        <span><span class="badge bg-light text-dark border">—</span> Εναπομείνασες: @Model.SessionBoxes.Count(b => b.IsEmpty)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Κουμπιά *@
    <div class="mt-3 d-print-none">
        <button onclick="window.print()" class="btn btn-primary">🖨️ Εκτύπωση</button>
        <a asp-page="Index" asp-route-memberId="@Model.Subscription.MemberId" class="btn btn-secondary">← Επιστροφή</a>
    </div>
</div>

@* Print CSS *@
<style>
    @@media print {
        .d-print-none { display: none !important; }
        nav, footer { display: none !important; }
        .container { max-width: 100% !important; }
    }
</style>
