@page "{gymProgramId:int}"
@model GymApp.Pages.TimeSlots.IndexModel

<div class="d-flex justify-content-between align-items-end mb-4 pb-3" style="border-bottom: 1px solid var(--border)">
    <div>
        <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:2px;color:var(--text-3);margin-bottom:4px">
            <i class="ti ti-arrow-left"></i>
            <a asp-page="/GymPrograms/Index" style="color:var(--text-3);text-decoration:none">Προγράμματα</a>
        </div>
        <h1 style="font-family:var(--font-display);font-size:2.5rem;letter-spacing:4px;color:var(--accent);line-height:1">ΠΡΟΓΡΑΜΜΑ</h1>
        <div style="font-size:.75rem;color:var(--text-3);margin-top:6px">
            <i class="ti ti-activity" style="color:var(--accent)"></i>
            <strong style="color:var(--text-2)">@Model.GymProgram.Name</strong>
            &nbsp;·&nbsp;
            <span>@Model.GymProgram.Trainer.Firstname @Model.GymProgram.Trainer.Lastname</span>
        </div>
    </div>
    <a asp-page="Create" asp-route-gymProgramId="@Model.GymProgram.Id" class="btn btn-primary"
           style="font-family:var(--font-display);letter-spacing:2px;font-size:.95rem;padding:10px 20px">
        <i class="ti ti-plus"></i> ΝΕΟ SLOT
    </a>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header" style="display:flex;align-items:center;gap:8px">
                <i class="ti ti-sun" style="color:var(--warm)"></i> ΠΡΩΙΝΑ ΤΜΗΜΑΤΑ
            </div>
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Ημέρα</th>
                        <th>Ώρα</th>
                        <th>Θέσεις</th>
                        <th>Ενέργειες</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.MorningSlots.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-3" style="color:var(--text-3)">
                                Δεν υπάρχουν πρωινά slots.
                            </td>
                        </tr>
                    }
                    @foreach (var slot in Model.MorningSlots)
                    {
                        <tr>
                            <td style="font-size:.82rem;font-weight:600;color:var(--text-1)">@DayName(slot.DayOfWeek)</td>
                            <td style="font-size:.82rem;font-family:var(--font-mono)">@slot.StartTime.ToString("HH:mm")</td>
                            <td>
                                <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--accent-md);color:var(--accent);font-weight:700;font-family:var(--font-mono)">
                                    @slot.Capacity
                                </span>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-page="Edit" asp-route-id="@slot.Id" class="btn btn-sm btn-secondary">
                                        <i class="ti ti-edit"></i>
                                    </a>
                                    <form method="post" asp-page="Delete" asp-route-id="@slot.Id">
                                        <input type="hidden" asp-for="@slot.GymProgramId" />
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="ti ti-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header" style="display:flex;align-items:center;gap:8px">
                <i class="ti ti-moon" style="color:var(--accent)"></i> ΑΠΟΓΕΥΜΑΤΙΝΑ ΤΜΗΜΑΤΑ
            </div>
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Ημέρα</th>
                        <th>Ώρα</th>
                        <th>Θέσεις</th>
                        <th>Ενέργειες</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.AfternoonSlots.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-3" style="color:var(--text-3)">
                                Δεν υπάρχουν απογευματινά slots.
                            </td>
                        </tr>
                    }
                    @foreach (var slot in Model.AfternoonSlots)
                    {
                        <tr>
                            <td style="font-size:.82rem;font-weight:600;color:var(--text-1)">@DayName(slot.DayOfWeek)</td>
                            <td style="font-size:.82rem;font-family:var(--font-mono)">@slot.StartTime.ToString("HH:mm")</td>
                            <td>
                                <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--accent-md);color:var(--accent);font-weight:700;font-family:var(--font-mono)">
                                    @slot.Capacity
                                </span>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-page="Edit" asp-route-id="@slot.Id" class="btn btn-sm btn-secondary">
                                        <i class="ti ti-edit"></i>
                                    </a>
                                    <form method="post" asp-page="Delete" asp-route-id="@slot.Id">
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="ti ti-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@functions {
    string DayName(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday => "Δευτέρα",
        DayOfWeek.Tuesday => "Τρίτη",
        DayOfWeek.Wednesday => "Τετάρτη",
        DayOfWeek.Thursday => "Πέμπτη",
        DayOfWeek.Friday => "Παρασκευή",
        DayOfWeek.Saturday => "Σάββατο",
        DayOfWeek.Sunday => "Κυριακή",
        _ => day.ToString()
    };
}