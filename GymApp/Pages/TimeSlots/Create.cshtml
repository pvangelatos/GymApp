@page "{gymProgramId:int}"
@model GymApp.Pages.TimeSlots.CreateModel

<div class="mb-4 pb-3" style="border-bottom: 1px solid var(--border)">
    <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:2px;color:var(--text-3);margin-bottom:4px">
        <i class="ti ti-arrow-left"></i>
        <a asp-page="Index" asp-route-gymProgramId="@Model.TimeSlot.GymProgramId" style="color:var(--text-3);text-decoration:none">Πρόγραμμα</a>
    </div>
    <h1 style="font-family:var(--font-display);font-size:3rem;letter-spacing:4px;color:var(--accent);line-height:1">ΝΕΟ SLOT</h1>
    <div style="font-size:.75rem;color:var(--text-3);margin-top:6px">
        <i class="ti ti-activity" style="color:var(--accent)"></i>
        <strong style="color:var(--text-2)">@Model.GymProgram.Name</strong>
    </div>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="TimeSlot.GymProgramId" />

                    <div class="mb-3">
                        <label asp-for="TimeSlot.DayOfWeek" class="form-label">Ημέρα</label>
                        <select asp-for="TimeSlot.DayOfWeek" asp-items="Model.DayOfWeekList" class="form-select">
                            <option value="">-- Επιλέξτε Ημέρα --</option>
                        </select>
                        <span asp-validation-for="TimeSlot.DayOfWeek" class="text-danger" style="font-size:.75rem"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TimeSlot.StartTime" class="form-label">Ώρα Έναρξης</label>
                        <input asp-for="TimeSlot.StartTime" type="time" class="form-control" />
                        <span asp-validation-for="TimeSlot.StartTime" class="text-danger" style="font-size:.75rem"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TimeSlot.SessionType" class="form-label">Τμήμα</label>
                        <select asp-for="TimeSlot.SessionType" asp-items="Model.SessionTypeList" class="form-select">
                            <option value="">-- Επιλέξτε Τμήμα --</option>
                        </select>
                        <span asp-validation-for="TimeSlot.SessionType" class="text-danger" style="font-size:.75rem"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TimeSlot.Capacity" class="form-label">Θέσεις</label>
                        <input asp-for="TimeSlot.Capacity" type="number" class="form-control" />
                        <span asp-validation-for="TimeSlot.Capacity" class="text-danger" style="font-size:.75rem"></span>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-device-floppy"></i> Αποθήκευση
                        </button>
                        <a asp-page="Index" asp-route-gymProgramId="@Model.TimeSlot.GymProgramId" class="btn btn-secondary">
                            <i class="ti ti-x"></i> Ακύρωση
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}