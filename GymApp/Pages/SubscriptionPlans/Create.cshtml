@page "{gymProgramId:int}"
@model GymApp.Pages.SubscriptionPlans.CreateModel

<div class="mb-4 pb-3" style="border-bottom: 1px solid var(--border)">
    <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:2px;color:var(--text-3);margin-bottom:4px">
        <i class="ti ti-arrow-left"></i>
        <a asp-page="Index" asp-route-gymProgramId="@Model.Plan.GymProgramId" style="color:var(--text-3);text-decoration:none">Πακέτα</a>
    </div>
    <h1 style="font-family:var(--font-display);font-size:3rem;letter-spacing:4px;color:var(--accent);line-height:1">ΝΕΟ ΠΑΚΕΤΟ</h1>
    <div style="font-size:.75rem;color:var(--text-3);margin-top:6px">
        <i class="ti ti-activity" style="color:var(--accent)"></i>
        <strong style="color:var(--text-2)">@Model.GymProgram.Name</strong>
    </div>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="Plan.GymProgramId" />

                    <div class="mb-3">
                        <label asp-for="Plan.SessionsPerMonth" class="form-label">Συνεδρίες ανά μήνα</label>
                        <select asp-for="Plan.SessionsPerMonth" class="form-select">
                            <option value="">-- Επιλέξτε --</option>
                            <option value="4">4 συνεδρίες (1/εβδομάδα)</option>
                            <option value="8">8 συνεδρίες (2/εβδομάδα)</option>
                            <option value="12">12 συνεδρίες (3/εβδομάδα)</option>
                        </select>
                        <span asp-validation-for="Plan.SessionsPerMonth" class="text-danger" style="font-size:.75rem"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Plan.Price" class="form-label">Τιμή (€)</label>
                        <input asp-for="Plan.Price" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="Plan.Price" class="text-danger" style="font-size:.75rem"></span>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-device-floppy"></i> Αποθήκευση
                        </button>
                        <a asp-page="Index" asp-route-gymProgramId="@Model.Plan.GymProgramId" class="btn btn-secondary">
                            <i class="ti ti-x"></i> Ακύρωση
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}