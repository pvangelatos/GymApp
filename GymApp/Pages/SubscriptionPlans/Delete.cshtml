@page "{id:int}"
@model GymApp.Pages.SubscriptionPlans.DeleteModel

<div class="mb-4 pb-3" style="border-bottom: 1px solid var(--border)">
    <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:2px;color:var(--text-3);margin-bottom:4px">
        <i class="ti ti-arrow-left"></i>
        <a asp-page="Index" asp-route-gymProgramId="@Model.Plan.GymProgramId" style="color:var(--text-3);text-decoration:none">Πακέτα</a>
    </div>
    <h1 style="font-family:var(--font-display);font-size:3rem;letter-spacing:4px;color:var(--red);line-height:1">ΔΙΑΓΡΑΦΗ ΠΑΚΕΤΟΥ</h1>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="alert alert-danger">
            <i class="ti ti-alert-triangle"></i> Είστε σίγουροι ότι θέλετε να διαγράψετε αυτό το πακέτο;
        </div>
        <div class="card">
            <div class="card-body">
                <dl style="display:grid;grid-template-columns:1fr 2fr;gap:10px 16px">
                    <dt style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Πρόγραμμα</dt>
                    <dd style="font-size:.85rem;color:var(--text-1);margin:0">@Model.Plan.GymProgram.Name</dd>
                    <dt style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Συνεδρίες</dt>
                    <dd style="font-size:.85rem;color:var(--text-1);margin:0">@Model.Plan.SessionsPerMonth / μήνα</dd>
                    <dt style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Τιμή</dt>
                    <dd style="font-size:.85rem;color:var(--text-1);margin:0;font-family:var(--font-mono)">@Model.Plan.Price.ToString("C", new System.Globalization.CultureInfo("el-GR"))</dd>
                </dl>
                <form method="post" class="mt-4">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="ti ti-trash"></i> Διαγραφή
                        </button>
                        <a asp-page="Index" asp-route-gymProgramId="@Model.Plan.GymProgramId" class="btn btn-secondary">
                            <i class="ti ti-x"></i> Ακύρωση
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>