@page
@model GymApp.Pages.Reports.WeeklyScheduleModel
@{
    string DayName(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday => "Δευτέρα",
        DayOfWeek.Tuesday => "Τρίτη",
        DayOfWeek.Wednesday => "Τετάρτη",
        DayOfWeek.Thursday => "Πέμπτη",
        DayOfWeek.Friday => "Παρασκευή",
        DayOfWeek.Saturday => "Σάββατο",
        _ => day.ToString()
    };
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📅 Εβδομαδιαίο Πρόγραμμα</h2>
        <a asp-page="/Index" class="btn btn-secondary">← Dashboard</a>
    </div>

    @* Πλοήγηση εβδομάδας *@
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-page="WeeklySchedule" asp-route-weekOffset="@(Request.Query["weekOffset"].Count > 0 ? int.Parse(Request.Query["weekOffset"].ToString()) - 1 : -1)"
           class="btn btn-outline-primary">← Προηγούμενη</a>
        <h5 class="mb-0">
            @Model.WeekStart.ToString("dd/MM/yyyy") — @Model.WeekEnd.ToString("dd/MM/yyyy")
        </h5>
        <a asp-page="WeeklySchedule" asp-route-weekOffset="@(Request.Query["weekOffset"].Count > 0 ? int.Parse(Request.Query["weekOffset"].ToString()) + 1 : 1)"
           class="btn btn-outline-primary">Επόμενη →</a>
        <a asp-page="WeeklySchedule" class="btn btn-outline-secondary">Τρέχουσα</a>
    </div>

    @* Εβδομαδιαίο grid *@
    <div class="row g-2">
        @foreach (var day in Model.Days)
        {
            var date = Model.WeekStart.AddDays(((int)day - (int)DayOfWeek.Monday + 7) % 7);
            var isToday = date.Date == DateTime.Today;
            var slots = Model.Schedule.ContainsKey(day) ? Model.Schedule[day] : new();

            <div class="col">
                <div class="card @(isToday ? "border-primary border-2" : "")">
                    <div class="card-header text-center @(isToday ? "bg-primary text-white" : "bg-light")">
                        <strong>@DayName(day)</strong>
                        <br />
                        <small>@date.ToString("dd/MM")</small>
                    </div>
                    <div class="card-body p-2">
                        @if (!slots.Any())
                        {
                            <p class="text-muted text-center small">Δεν υπάρχουν μαθήματα</p>
                        }
                        @foreach (var slot in slots.OrderBy(s => s.TimeSlot.StartTime))
                        {
                            var slotModalId = $"modal_{slot.TimeSlot.Id}_{date:yyyyMMdd}";
    
                            <div class="card mb-2 @(slot.IsFull ? "border-danger" : "border-success")"
                                 style="font-size: 0.85rem; cursor: pointer;"
                                 data-bs-toggle="modal"
                                 data-bs-target="#@slotModalId">
                                <div class="card-body p-2">
                                    <div class="fw-bold">@slot.TimeSlot.GymProgram.Name</div>
                                    <div class="text-muted">@slot.TimeSlot.StartTime.ToString("HH:mm")</div>
                                    <div class="text-muted small">@slot.TimeSlot.GymProgram.Trainer.Firstname @slot.TimeSlot.GymProgram.Trainer.Lastname</div>
                                    <div class="mt-1">
                                        @if (slot.IsFull)
                                        {
                                            <span class="badge bg-danger">Πλήρες</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">@slot.AvailableCount/@slot.TimeSlot.Capacity</span>
                                        }
                                    </div>
                                    @if (slot.Bookings.Any())
                                    {
                                        <hr class="my-1" />
                                        @foreach (var booking in slot.Bookings)
                                        {
                                            <div class="small">
                                                @if (booking.Status == GymApp.Models.BookingStatus.Attended)
                                                {
                                                    <span class="text-success">✓</span>
                                                }
                                                else
                                                {
                                                    <span class="text-primary">●</span>
                                                }
                                                @booking.MemberName
                                            </div>
                                        }
                                    }
                                </div>
                            </div>

                            @* Modal για κράτηση *@
                            <div class="modal fade" id="@slotModalId" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">
                                                @slot.TimeSlot.GymProgram.Name — @slot.TimeSlot.StartTime.ToString("HH:mm") — @date.ToString("dd/MM/yyyy")
                                            </h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <p class="text-muted">Διαθέσιμες θέσεις: <strong>@slot.AvailableCount/@slot.TimeSlot.Capacity</strong></p>
                    
                                            @if (!slot.AvailableMembers.Any())
                                            {
                                                <div class="alert alert-info">Δεν υπάρχουν μέλη με ενεργή συνδρομή για αυτό το πρόγραμμα.</div>
                                            }
                                            else
                                            {
                                                <table class="table table-sm">
                                                    <thead>
                                                        <tr>
                                                            <th>Μέλος</th>
                                                            <th>Εναπομείνασες</th>
                                                            <th></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var member in slot.AvailableMembers.OrderBy(m => m.MemberName))
                                                        {
                                                            <tr class="@(member.AlreadyBooked ? "table-secondary" : "")">
                                                                <td>@member.MemberName</td>
                                                                <td>
                                                                    @if (member.AlreadyBooked)
                                                                    {
                                                                        <span class="badge bg-secondary">Κλεισμένο</span>
                                                                    }
                                                                    else if (member.RemainingSessions <= 0)
                                                                    {
                                                                        <span class="badge bg-danger">Εξαντλήθηκαν</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="badge bg-success">@member.RemainingSessions</span>
                                                                    }
                                                                </td>
                                                                <td>
                                                                    @if (!member.AlreadyBooked && member.RemainingSessions > 0 && !slot.IsFull)
                                                                    {
                                                                        <form method="post" asp-page-handler="Book">
                                                                            <input type="hidden" name="BookingSubscriptionId" value="@member.SubscriptionId" />
                                                                            <input type="hidden" name="BookingTimeSlotId" value="@slot.TimeSlot.Id" />
                                                                            <input type="hidden" name="BookingDate" value="@date.ToString("yyyy-MM-dd")" />
                                                                            <input type="hidden" name="WeekOffset" value="@Request.Query["weekOffset"]" />
                                                                            <button type="submit" class="btn btn-sm btn-primary">Κράτηση</button>
                                                                        </form>
                                                                    }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Κλείσιμο</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>