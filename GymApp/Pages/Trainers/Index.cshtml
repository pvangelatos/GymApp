@page
@model GymApp.Pages.Trainers.IndexModel

<div class="d-flex justify-content-between align-items-end mb-4 pb-3" style="border-bottom: 1px solid var(--border)">
    <div>
        <h1 style="font-family:var(--font-display);font-size:3rem;letter-spacing:4px;color:var(--accent);line-height:1">ΕΚΠΑΙΔΕΥΤΕΣ</h1>
        <div style="font-size:.75rem;color:var(--text-3);margin-top:6px">
            Σύνολο: <strong style="color:var(--text-2)">@Model.Trainers.Count</strong> εκπαιδευτές
        </div>
    </div>
    <a asp-page="Create" class="btn btn-primary" style="font-family:var(--font-display);letter-spacing:2px;font-size:.95rem;padding:10px 20px">
        <i class="ti ti-plus"></i> ΝΕΟΣ ΕΚΠΑΙΔΕΥΤΗΣ
    </a>
</div>

<div class="card">
    <table class="table mb-0">
        <thead>
            <tr>
                <th>Εκπαιδευτής</th>
                <th>Email</th>
                <th>Τηλέφωνο</th>
                <th>Ενέργειες</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Trainers.Any())
            {
                <tr>
                    <td colspan="4" class="text-center py-4" style="color:var(--text-3)">
                        <i class="ti ti-user-off" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                        Δεν βρέθηκαν εκπαιδευτές.
                    </td>
                </tr>
            }
            @foreach (var trainer in Model.Trainers)
            {
                <tr>
                    <td style="white-space:nowrap">
                        <div style="display:flex;align-items:center;gap:10px">
                            <div style="width:36px;height:36px;border-radius:50%;background:var(--olive-lt);border:1.5px solid var(--olive);display:flex;align-items:center;justify-content:center;font-size:.68rem;font-weight:700;color:var(--olive);flex-shrink:0;font-family:var(--font-mono)">
                                @(trainer.Lastname.Length > 0 ? trainer.Lastname[0].ToString() : "")@(trainer.Firstname.Length > 0 ? trainer.Firstname[0].ToString() : "")
                            </div>
                            <div>
                                <div style="font-weight:600;color:var(--text-1);font-size:.85rem">@trainer.Lastname @trainer.Firstname</div>
                            </div>
                        </div>
                    </td>
                    <td style="font-size:.82rem">@trainer.Email</td>
                    <td style="white-space:nowrap;font-size:.82rem;font-family:var(--font-mono)">@trainer.Phone</td>
                    <td>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="ti ti-dots"></i> Ενέργειες
                            </button>
                            <ul class="dropdown-menu" style="background:var(--bg-3);border:1px solid var(--border)">
                                <li>
                                    <a class="dropdown-item" asp-page="Edit" asp-route-id="@trainer.Id"
                                           style="font-size:.82rem;color:var(--text-2)">
                                        <i class="ti ti-edit" style="color:var(--warm)"></i> Επεξεργασία
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" style="border-color:var(--border)"></li>
                                <li>
                                    <a class="dropdown-item" style="font-size:.82rem;color:var(--red);cursor:pointer"
                                           data-bs-toggle="modal" data-bs-target="#deleteModal_@trainer.Id">
                                        <i class="ti ti-trash"></i> Διαγραφή
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </td>
                </tr>
                <div class="modal fade" id="deleteModal_@trainer.Id" tabindex="-1">
                    <div class="modal-dialog modal-sm">
                        <div class="modal-content" style="background:var(--bg-3);border:1px solid var(--border)">
                            <div class="modal-header" style="border-bottom:1px solid var(--border)">
                                <div style="font-family:var(--font-display);font-size:1.1rem;letter-spacing:2px;color:var(--red)">
                                    ΔΙΑΓΡΑΦΗ ΕΚΠΑΙΔΕΥΤΗ
                                </div>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <p style="font-size:.85rem;color:var(--text-2)">
                                    Θέλετε να διαγράψετε τον εκπαιδευτή:
                                </p>
                                <div style="font-weight:700;color:var(--text-1);font-size:.9rem">
                                    @trainer.Lastname @trainer.Firstname
                                </div>
                            </div>
                            <div class="modal-footer" style="border-top:1px solid var(--border)">
                                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                                    <i class="ti ti-x"></i> Ακύρωση
                                </button>
                                <form method="post" asp-page="Delete" asp-route-id="@trainer.Id">
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="ti ti-trash"></i> Διαγραφή
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </tbody>
    </table>
</div>