@page "{subscriptionId:int}"
@model GymApp.Pages.Payments.IndexModel

<div class="d-flex justify-content-between align-items-end mb-4 pb-3" style="border-bottom: 1px solid var(--border)">
    <div>
        <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:2px;color:var(--text-3);margin-bottom:4px">
            <i class="ti ti-arrow-left"></i>
            <a asp-page="/Subscriptions/Index" asp-route-memberId="@Model.Subscription.MemberId" style="color:var(--text-3);text-decoration:none">Συνδρομές</a>
        </div>
        <h1 style="font-family:var(--font-display);font-size:2.5rem;letter-spacing:4px;color:var(--accent);line-height:1">ΠΛΗΡΩΜΕΣ</h1>
        <div style="font-size:.75rem;color:var(--text-3);margin-top:6px">
            <i class="ti ti-user" style="color:var(--accent)"></i>
            <strong style="color:var(--text-2)">@Model.Subscription.Member.Lastname @Model.Subscription.Member.Firstname</strong>
            &nbsp;·&nbsp;
            <span>@Model.Subscription.SubscriptionPlan.GymProgram.Name</span>
        </div>
    </div>
    <a asp-page="Create" asp-route-subscriptionId="@Model.Subscription.Id" class="btn btn-primary"
           style="font-family:var(--font-display);letter-spacing:2px;font-size:.95rem;padding:10px 20px">
        <i class="ti ti-plus"></i> ΝΕΑ ΠΛΗΡΩΜΗ
    </a>
</div>

@* Κάρτες *@
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card" style="border-top:3px solid var(--accent) !important">
            <div class="card-body">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                    <span style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Αξία Συνδρομής</span>
                    <i class="ti ti-tag" style="color:var(--accent);font-size:1rem"></i>
                </div>
                <div style="font-family:var(--font-display);font-size:1.6rem;letter-spacing:2px;color:var(--text-1)">@Model.Subscription.AmountPaid.ToString("C", new System.Globalization.CultureInfo("el-GR"))</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card" style="border-top:3px solid var(--olive) !important">
            <div class="card-body">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                    <span style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Καταβλήθηκε</span>
                    <i class="ti ti-check" style="color:var(--olive);font-size:1rem"></i>
                </div>
                <div style="font-family:var(--font-display);font-size:1.6rem;letter-spacing:2px;color:var(--text-1)">@Model.TotalPaid.ToString("C", new System.Globalization.CultureInfo("el-GR"))</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card" style="border-top:3px solid var(--warm) !important">
            <div class="card-body">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                    <span style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Υπόλοιπο</span>
                    <i class="ti ti-clock" style="color:var(--warm);font-size:1rem"></i>
                </div>
                <div style="font-family:var(--font-display);font-size:1.6rem;letter-spacing:2px;color:var(--text-1)">@((Model.Subscription.AmountPaid - Model.TotalPaid).ToString("C", new System.Globalization.CultureInfo("el-GR")))</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card" style="border-top:3px solid var(--brown-mid) !important">
            <div class="card-body">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                    <span style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Με Απόδειξη</span>
                    <i class="ti ti-receipt" style="color:var(--brown-mid);font-size:1rem"></i>
                </div>
                <div style="font-family:var(--font-display);font-size:1.6rem;letter-spacing:2px;color:var(--text-1)">@Model.TotalWithReceipt.ToString("C", new System.Globalization.CultureInfo("el-GR"))</div>
            </div>
        </div>
    </div>
</div>

@if (!Model.Payments.Any())
{
    <div class="card">
        <div class="card-body text-center py-4" style="color:var(--text-3)">
            <i class="ti ti-receipt-off" style="font-size:2rem;display:block;margin-bottom:8px"></i>
            Δεν υπάρχουν πληρωμές για αυτή τη συνδρομή.
        </div>
    </div>
}
else
{
    <div class="card">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Ημερομηνία</th>
                    <th>Ποσό</th>
                    <th>Τρόπος</th>
                    <th>Απόδειξη</th>
                    <th>Σημειώσεις</th>
                    <th>Ενέργειες</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var payment in Model.Payments)
                {
                    <tr>
                        <td style="font-size:.82rem;font-family:var(--font-mono);white-space:nowrap">@payment.PaymentDate.ToShortDateString()</td>
                        <td style="font-size:.85rem;font-weight:600;color:var(--text-1);font-family:var(--font-mono)">@payment.Amount.ToString("C", new System.Globalization.CultureInfo("el-GR"))</td>
                        <td>
                            @switch (payment.PaymentMethod)
                            {
                                case GymApp.Models.PaymentMethod.Cash:
                                    <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--olive-lt);color:var(--olive);font-weight:600">
                                        <i class="ti ti-cash"></i> Μετρητά
                                    </span>
                                    break;
                                case GymApp.Models.PaymentMethod.Card:
                                    <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--accent-lt);color:var(--accent);font-weight:600">
                                        <i class="ti ti-credit-card"></i> Κάρτα
                                    </span>
                                    break;
                                case GymApp.Models.PaymentMethod.Transfer:
                                    <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--warm-lt);color:var(--warm);font-weight:600">
                                        <i class="ti ti-building-bank"></i> Transfer
                                    </span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (payment.HasReceipt)
                            {
                                <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--olive-lt);color:var(--olive);font-weight:600">
                                    <i class="ti ti-check"></i> Ναι
                                </span>
                            }
                            else
                            {
                                <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--bg-4);color:var(--text-3);font-weight:600">
                                    <i class="ti ti-x"></i> Όχι
                                </span>
                            }
                        </td>
                        <td style="font-size:.82rem;color:var(--text-2)">@payment.Notes</td>
                        <td>
                            <a class="btn btn-sm btn-danger" style="cursor:pointer"
                                   data-bs-toggle="modal" data-bs-target="#deleteModal_@payment.Id">
                                <i class="ti ti-trash"></i>
                            </a>
                        </td>
                    </tr>
                    <div class="modal fade" id="deleteModal_@payment.Id" tabindex="-1">
                        <div class="modal-dialog modal-sm">
                            <div class="modal-content" style="background:var(--bg-3);border:1px solid var(--border)">
                                <div class="modal-header" style="border-bottom:1px solid var(--border)">
                                    <div style="font-family:var(--font-display);font-size:1.1rem;letter-spacing:2px;color:var(--red)">
                                        ΔΙΑΓΡΑΦΗ ΠΛΗΡΩΜΗΣ
                                    </div>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <dl style="display:grid;grid-template-columns:1fr 2fr;gap:8px 16px">
                                        <dt style="font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Ημερομηνία</dt>
                                        <dd style="font-size:.85rem;color:var(--text-1);margin:0;font-family:var(--font-mono)">@payment.PaymentDate.ToShortDateString()</dd>
                                        <dt style="font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Ποσό</dt>
                                        <dd style="font-size:.85rem;font-weight:700;color:var(--text-1);margin:0;font-family:var(--font-mono)">@payment.Amount.ToString("C", new System.Globalization.CultureInfo("el-GR"))</dd>
                                        <dt style="font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Απόδειξη</dt>
                                        <dd style="font-size:.85rem;color:var(--text-1);margin:0">@(payment.HasReceipt ? "Ναι" : "Όχι")</dd>
                                    </dl>
                                </div>
                                <div class="modal-footer" style="border-top:1px solid var(--border)">
                                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                                        <i class="ti ti-x"></i> Ακύρωση
                                    </button>
                                    <form method="post" asp-page="Delete" asp-route-id="@payment.Id">
                                        <input type="hidden" name="Payment.SubscriptionId" value="@payment.SubscriptionId" />
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="ti ti-trash"></i> Διαγραφή
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
}