@page "{subscriptionId:int}"
@model GymApp.Pages.Payments.CreateModel

<div class="mb-4 pb-3" style="border-bottom: 1px solid var(--border)">
    <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:2px;color:var(--text-3);margin-bottom:4px">
        <i class="ti ti-arrow-left"></i>
        <a asp-page="Index" asp-route-subscriptionId="@Model.Subscription.Id" style="color:var(--text-3);text-decoration:none">Πληρωμές</a>
    </div>
    <h1 style="font-family:var(--font-display);font-size:3rem;letter-spacing:4px;color:var(--accent);line-height:1">ΝΕΑ ΠΛΗΡΩΜΗ</h1>
    <div style="font-size:.75rem;color:var(--text-3);margin-top:6px">
        <i class="ti ti-user" style="color:var(--accent)"></i>
        <strong style="color:var(--text-2)">@Model.Subscription.Member.Lastname @Model.Subscription.Member.Firstname</strong>
        &nbsp;·&nbsp;
        <span>@Model.Subscription.SubscriptionPlan.GymProgram.Name</span>
    </div>
</div>

<div class="row">
    <div class="col-md-5">
        @if (!ModelState.IsValid)
        {
            <div class="alert alert-danger mb-3">
                @foreach (var error in ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p class="mb-0"><i class="ti ti-alert-circle"></i> @error.ErrorMessage</p>
                }
            </div>
        }

        <div class="card">
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="Payment.SubscriptionId" />

                    <div class="mb-3">
                        <label asp-for="Payment.PaymentDate" class="form-label">Ημερομηνία Πληρωμής</label>
                        <input asp-for="Payment.PaymentDate" type="date" class="form-control"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Payment.Amount" class="form-label">Ποσό (€)</label>
                        <input asp-for="Payment.Amount" type="number" step="0.01" class="form-control" />
                        <div class="form-text" style="font-size:.72rem;color:var(--text-3)">
                            <i class="ti ti-info-circle"></i> Υπόλοιπο: @Model.Payment.Amount.ToString("C", new System.Globalization.CultureInfo("el-GR"))
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Payment.PaymentMethod" class="form-label">Τρόπος Πληρωμής</label>
                        <select asp-for="Payment.PaymentMethod" asp-items="Model.PaymentMethodList" class="form-select"></select>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="Payment.HasReceipt" class="form-check-input" type="checkbox" />
                            <label asp-for="Payment.HasReceipt" class="form-check-label">
                                <i class="ti ti-receipt"></i> Κόπηκε Απόδειξη
                            </label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Payment.Notes" class="form-label">Σημειώσεις</label>
                        <input asp-for="Payment.Notes" class="form-control" placeholder="Προαιρετικό..." />
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-device-floppy"></i> Αποθήκευση
                        </button>
                        <a asp-page="Index" asp-route-subscriptionId="@Model.Payment.SubscriptionId" class="btn btn-secondary">
                            <i class="ti ti-x"></i> Ακύρωση
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}