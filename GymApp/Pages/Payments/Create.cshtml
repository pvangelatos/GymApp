@page "{subscriptionId:int}"
@model GymApp.Pages.Payments.CreateModel

<div class="container mt-4">
    <h2>💳 Νέα Πληρωμή</h2>
    <p class="text-muted">
        @Model.Subscription.Member.Lastname @Model.Subscription.Member.Firstname —
        @Model.Subscription.SubscriptionPlan.GymProgram.Name
    </p>
    <hr />

    @if (!ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var error in ModelState.Values.SelectMany(v => v.Errors))
            {
                <p class="mb-0">@error.ErrorMessage</p>
            }
        </div>
    }

    <form method="post">
        <input type="hidden" asp-for="Payment.SubscriptionId" />

        <div class="mb-3">
            <label asp-for="Payment.PaymentDate" class="form-label">Ημερομηνία Πληρωμής</label>
            <input asp-for="Payment.PaymentDate" type="date" class="form-control"
                   value="@DateTime.Today.ToString("yyyy-MM-dd")" />
        </div>
        <div class="mb-3">
            <label asp-for="Payment.Amount" class="form-label">Ποσό (€)</label>
            <input asp-for="Payment.Amount" type="number" step="0.01" class="form-control" />
            <div class="form-text">Υπόλοιπο: @Model.Payment.Amount.ToString("C", new System.Globalization.CultureInfo("el-GR"))</div>
        </div>
        <div class="mb-3">
            <label asp-for="Payment.PaymentMethod" class="form-label">Τρόπος Πληρωμής</label>
            <select asp-for="Payment.PaymentMethod" asp-items="Model.PaymentMethodList" class="form-select"></select>
        </div>
        <div class="mb-3">
            <div class="form-check">
                <input asp-for="Payment.HasReceipt" class="form-check-input" type="checkbox" />
                <label asp-for="Payment.HasReceipt" class="form-check-label">Κόπηκε Απόδειξη</label>
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="Payment.Notes" class="form-label">Σημειώσεις</label>
            <input asp-for="Payment.Notes" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Αποθήκευση</button>
        <a asp-page="Index" asp-route-subscriptionId="@Model.Payment.SubscriptionId" class="btn btn-secondary">Ακύρωση</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
