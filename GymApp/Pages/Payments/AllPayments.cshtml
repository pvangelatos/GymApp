@page
@model GymApp.Pages.Payments.AllPaymentsModel

<div class="mb-4 pb-3" style="border-bottom: 1px solid var(--border)">
    <h1 style="font-family:var(--font-display);font-size:3rem;letter-spacing:4px;color:var(--accent);line-height:1">ΠΛΗΡΩΜΕΣ</h1>
    <div style="font-size:.75rem;color:var(--text-3);margin-top:6px">Όλες οι πληρωμές</div>
</div>

@* Κάρτες *@
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card" style="border-top:3px solid var(--accent) !important">
            <div class="card-body">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                    <span style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Σύνολο Πληρωμών</span>
                    <i class="ti ti-cash" style="color:var(--accent);font-size:1rem"></i>
                </div>
                <div style="font-family:var(--font-display);font-size:1.8rem;letter-spacing:2px;color:var(--text-1)">@Model.TotalPaid.ToString("C", new System.Globalization.CultureInfo("el-GR"))</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card" style="border-top:3px solid var(--olive) !important">
            <div class="card-body">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                    <span style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Με Απόδειξη</span>
                    <i class="ti ti-receipt" style="color:var(--olive);font-size:1rem"></i>
                </div>
                <div style="font-family:var(--font-display);font-size:1.8rem;letter-spacing:2px;color:var(--text-1)">@Model.TotalWithReceipt.ToString("C", new System.Globalization.CultureInfo("el-GR"))</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card" style="border-top:3px solid var(--warm) !important">
            <div class="card-body">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                    <span style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3)">Χωρίς Απόδειξη</span>
                    <i class="ti ti-receipt-off" style="color:var(--warm);font-size:1rem"></i>
                </div>
                <div style="font-family:var(--font-display);font-size:1.8rem;letter-spacing:2px;color:var(--text-1)">@Model.TotalWithoutReceipt.ToString("C", new System.Globalization.CultureInfo("el-GR"))</div>
            </div>
        </div>
    </div>
</div>

@if (!Model.Payments.Any())
{
    <div class="card">
        <div class="card-body text-center py-4" style="color:var(--text-3)">
            <i class="ti ti-receipt-off" style="font-size:2rem;display:block;margin-bottom:8px"></i>
            Δεν υπάρχουν πληρωμές.
        </div>
    </div>
}
else
{
    <div class="card">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Μέλος</th>
                    <th>Πρόγραμμα</th>
                    <th>Ημερομηνία</th>
                    <th>Ποσό</th>
                    <th>Τρόπος</th>
                    <th>Απόδειξη</th>
                    <th>Σημειώσεις</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var payment in Model.Payments)
                {
                    <tr>
                        <td style="white-space:nowrap">
                            <div style="display:flex;align-items:center;gap:8px">
                                <div style="width:28px;height:28px;border-radius:50%;background:var(--accent-md);border:1.5px solid var(--accent);display:flex;align-items:center;justify-content:center;font-size:.6rem;font-weight:700;color:var(--accent);font-family:var(--font-mono)">
                                    @(payment.Subscription.Member.Lastname[0])@(payment.Subscription.Member.Firstname[0])
                                </div>
                                <span style="font-weight:600;font-size:.82rem;color:var(--text-1)">@payment.Subscription.Member.Lastname @payment.Subscription.Member.Firstname</span>
                            </div>
                        </td>
                        <td style="font-size:.82rem">@payment.Subscription.SubscriptionPlan.GymProgram.Name</td>
                        <td style="font-size:.82rem;font-family:var(--font-mono);white-space:nowrap">@payment.PaymentDate.ToShortDateString()</td>
                        <td style="font-size:.85rem;font-weight:700;color:var(--text-1);font-family:var(--font-mono)">@payment.Amount.ToString("C", new System.Globalization.CultureInfo("el-GR"))</td>
                        <td>
                            @switch (payment.PaymentMethod)
                            {
                                case GymApp.Models.PaymentMethod.Cash:
                                    <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--olive-lt);color:var(--olive);font-weight:600">
                                        <i class="ti ti-cash"></i> Μετρητά
                                    </span>
                                    break;
                                case GymApp.Models.PaymentMethod.Card:
                                    <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--accent-lt);color:var(--accent);font-weight:600">
                                        <i class="ti ti-credit-card"></i> Κάρτα
                                    </span>
                                    break;
                                case GymApp.Models.PaymentMethod.Transfer:
                                    <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--warm-lt);color:var(--warm);font-weight:600">
                                        <i class="ti ti-building-bank"></i> Transfer
                                    </span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (payment.HasReceipt)
                            {
                                <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--olive-lt);color:var(--olive);font-weight:600">
                                    <i class="ti ti-check"></i> Ναι
                                </span>
                            }
                            else
                            {
                                <span style="font-size:.75rem;padding:3px 8px;border-radius:4px;background:var(--bg-4);color:var(--text-3);font-weight:600">
                                    <i class="ti ti-x"></i> Όχι
                                </span>
                            }
                        </td>
                        <td style="font-size:.82rem;color:var(--text-2)">@payment.Notes</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
